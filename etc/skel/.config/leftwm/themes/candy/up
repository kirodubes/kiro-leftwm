#!/bin/bash
export SCRIPTPATH="$( cd "$(dirname "$0")" ; pwd -P )"

# run() — start a program only if it is not already running. The theme `up`
# script re-runs on every theme reload, and `down` only kills polybar /
# fastcompmgr / dunst / volumeicon — so this guard stops the other tray applets
# from stacking up duplicates on reload.
run() {
  if ! pgrep -x "$(basename "$1" | head -c 15)" >/dev/null; then
    "$@" &
  fi
}

# Down the last running theme
if [ -f "/tmp/leftwm-theme-down" ]; then
    /tmp/leftwm-theme-down
    rm /tmp/leftwm-theme-down
fi
ln -s $SCRIPTPATH/down /tmp/leftwm-theme-down

# Monitor layout — detect connected screens and arrange them left-to-right.
# Must run before the polybar loop so bars get the correct geometry.
~/.config/leftwm/scripts/monitor-layout.sh

# Keyboard layout: QWERTY is the shipped default (config.ron); a Belgian (be)
# layout auto-loads the AZERTY config. Same detect as the kiro theme.
keybLayout=$(setxkbmap -v | awk -F "+" '/symbols/ {print $2}')
if [ "$keybLayout" = "be" ]; then
  cp ~/.config/leftwm/config-azerty.ron ~/.config/leftwm/config.ron
fi

# keybindings daemon
killall sxhkd 2>/dev/null
sxhkd -c ~/.config/leftwm/sxhkd/sxhkdrc &

# diversity of apps to start
run fastcompmgr
run nm-applet
run pamac-tray
run xfce4-power-manager
run numlockx on
run blueberry-tray
run /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
run /usr/lib/xfce4/notifyd/xfce4-notifyd
run volumeicon
run xfce4-clipman

# Set the theme.ron config
leftwm command "LoadTheme $SCRIPTPATH/theme.ron"

# Set background
if [ -x "$(command -v feh)" ]; then
  feh --bg-fill "$SCRIPTPATH"/background.jpg
fi

#mainbar
index=0
# Map each connected monitor to its x-offset (from `polybar -m`) so every bar
# lands on the screen whose workspace it controls: mainbarN drives leftwm
# workspace N, so we place it on the monitor at workspace N's x position.
# Pairing by raw `polybar -m` order breaks when leftwm's workspace order and
# polybar's monitor order disagree (e.g. after a primary-monitor swap).
declare -A monitor_at_x
while IFS= read -r mline; do
  mname="${mline%%:*}"; mgeom="${mline#*: }"; mgeom="${mgeom%% *}"
  mx="${mgeom#*+}"; mx="${mx%%+*}"
  monitor_at_x[$mx]="$mname"
done < <(polybar -m)
leftwm-state -q -n -t "$SCRIPTPATH"/sizes.liquid | sed -r '/^\s*$/d' | while read -r width x y
do
  barname="mainbar$index"
  monitor=${monitor_at_x[$x]} width=$(( width - 16 )) polybar -c "$SCRIPTPATH"/polybar/config.ini $barname &> /dev/null &
  let index=index+1
done
